# Shopify
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
SHOPIFY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_hmac_secret

# Mock ERP
ERP_BASE_URL=https://mock-erp.internal/api/v1
ERP_API_KEY=erp_api_key_here
ERP_WAREHOUSE_ID=WH-001

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# AWS (for Lambda deployment)
AWS_REGION=us-east-1
AWS_LAMBDA_FUNCTION_NAME=shopify-erp-sync
